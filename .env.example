# ---------------------------------------------------------------------------
# Huginn hub configuration. Copy to .env and fill in. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# --- Core ---
HUGINN_ENV=dev                      # dev | prod
HUGINN_LOG_LEVEL=INFO

# --- Database (async SQLAlchemy / asyncpg) ---
HUGINN_DATABASE_URL=postgresql+asyncpg://huginn:huginn@postgres:5432/huginn

# --- Security ---
# 32+ byte random secret used to sign JWTs. Generate: openssl rand -hex 32
HUGINN_JWT_SECRET=change-me-please-generate-a-real-secret
HUGINN_JWT_ALGORITHM=HS256
HUGINN_ACCESS_TOKEN_TTL_MINUTES=60

# HMAC key used to hash enrollment tokens and worker secrets at rest.
# Generate: openssl rand -hex 32
HUGINN_SECRET_HASH_KEY=change-me-another-32-byte-secret

# Service token presented by the MCP server to the hub's internal API.
# Generate: openssl rand -hex 32
HUGINN_MCP_SERVICE_TOKEN=change-me-mcp-service-token

# --- TLS policy for hub<->worker ---
# In prod the hub refuses to register/serve workers over plaintext HTTP.
HUGINN_REQUIRE_TLS=true

# --- First admin user (bootstrapped on startup if no users exist) ---
HUGINN_BOOTSTRAP_ADMIN_USERNAME=admin
HUGINN_BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# --- OIDC / Authentik (optional; leave blank to disable OIDC login) ---
HUGINN_OIDC_ENABLED=false
HUGINN_OIDC_ISSUER=https://authentik.example.com/application/o/huginn/
HUGINN_OIDC_CLIENT_ID=
HUGINN_OIDC_CLIENT_SECRET=
HUGINN_OIDC_REDIRECT_URL=http://localhost:8000/api/auth/oidc/callback

# --- Execution limits ---
HUGINN_MAX_BODY_BYTES=65536         # max request body on exec endpoints
HUGINN_MAX_OUTPUT_BYTES=1048576     # max stdout/stderr stored per task
HUGINN_DEFAULT_TASK_TIMEOUT_SECONDS=60
HUGINN_TASK_DEAD_LETTER_RETRIES=3
HUGINN_RATE_LIMIT_EXEC_PER_MINUTE=30
HUGINN_HEARTBEAT_OFFLINE_SECONDS=120   # mark VM OFFLINE after this with no heartbeat

# --- Worker update / release source (SSRF allowlist) ---
HUGINN_TARGET_WORKER_VERSION=v0.1.0
HUGINN_TARGET_RELEASE_REPO=Cronos-website/Huginn
HUGINN_ALLOWED_RELEASE_DOMAINS=github.com,objects.githubusercontent.com

# ---------------------------------------------------------------------------
# Worker-side install (used by scripts/install.sh)
# ---------------------------------------------------------------------------
# HUB_URL=https://hub.example.com
# TOKEN=<enrollment-token-from-dashboard>
