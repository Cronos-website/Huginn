# Production Docker Compose config. Copy to .env.prod and fill in.
# Generate each secret with: openssl rand -hex 32

# Host Caddy serves. A real public domain, an IP (e.g. 172.16.2.5), or localhost.
HUGINN_DOMAIN=huginn.example.com
# Certificates:
#   internal        -> self-signed (use for an IP / LAN / localhost; browser warns)
#   you@example.com -> automatic Let's Encrypt (ONLY with a real public domain)
HUGINN_TLS_INTERNAL=internal

# PostgreSQL
POSTGRES_USER=huginn
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=huginn

# Hub secrets (the hub refuses to start in prod with placeholder/short secrets).
HUGINN_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
HUGINN_SECRET_HASH_KEY=CHANGE_ME_openssl_rand_hex_32
HUGINN_MCP_SERVICE_TOKEN=CHANGE_ME_openssl_rand_hex_32
# Dedicated key encrypting TOTP secrets at rest. MUST differ from the others.
HUGINN_MFA_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# MFA / passkeys.
# Force local admins to enrol a second factor before using the dashboard.
HUGINN_REQUIRE_ADMIN_MFA=true
# WebAuthn relying party. rp_id MUST be a registrable domain (NOT a bare IP),
# so passkeys only work over this domain. Defaults to HUGINN_DOMAIN.
HUGINN_WEBAUTHN_RP_ID=huginn.example.com
HUGINN_WEBAUTHN_RP_NAME=Huginn
HUGINN_WEBAUTHN_ORIGIN=https://huginn.example.com
# "preferred" works with the widest range of keys (incl. a PIN-less YubiKey);
# "required" enforces a PIN/biometric for stricter passwordless MFA.
HUGINN_WEBAUTHN_USER_VERIFICATION=preferred
# SSO-first: when OIDC is enabled, the password login form is disabled unless
# this is true ("unsafe" opt-in). With OIDC off, password login is always on.
HUGINN_ALLOW_PASSWORD_LOGIN=false

# First admin (rotate the password after first login).
HUGINN_BOOTSTRAP_ADMIN_USERNAME=admin
HUGINN_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_on_first_login

# Worker releases.
HUGINN_TARGET_RELEASE_REPO=Sunderrrr/Huginn
HUGINN_TARGET_WORKER_VERSION=v1.3.0
