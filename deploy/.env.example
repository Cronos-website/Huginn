# Copy to deploy/.env and fill in. Generate secrets with: openssl rand -hex 32
POSTGRES_USER=huginn
POSTGRES_PASSWORD=huginn
POSTGRES_DB=huginn

HUGINN_ENV=dev
HUGINN_REQUIRE_TLS=false

HUGINN_JWT_SECRET=change-me-openssl-rand-hex-32
HUGINN_SECRET_HASH_KEY=change-me-openssl-rand-hex-32
HUGINN_MCP_SERVICE_TOKEN=change-me-openssl-rand-hex-32

HUGINN_BOOTSTRAP_ADMIN_USERNAME=admin
HUGINN_BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# MCP agent auth: there is no shared client token. Each user creates their own
# per-user MCP token in the dashboard (MCP Tokens page) and sends it as
# `Authorization: Bearer <token>`. Only HUGINN_MCP_SERVICE_TOKEN (above) is
# needed in the environment, for MCP-server-to-hub trust.

HUGINN_TARGET_RELEASE_REPO=Sunderrrr/Huginn
# Worker version the fleet should run (seeds the hub's target on first boot;
# afterwards manage it from the dashboard). Use the latest released worker.
HUGINN_TARGET_WORKER_VERSION=v1.3.0
